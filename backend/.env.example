# ─────────────────────────────────────────────────────────────────────────────
# LLM Platform — Backend Environment Variables
# Copy this file to .env and edit the values for your setup.
# cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Connection string for your MongoDB instance
MONGO_URL=mongodb://localhost:27017

# Database name (created automatically on first run)
MONGO_DB_NAME=llmplatform

# ── Redis ─────────────────────────────────────────────────────────────────────
# Used by Celery for the task queue and live progress pub/sub
REDIS_URL=redis://localhost:6379/0

# ── Qdrant ────────────────────────────────────────────────────────────────────
# Qdrant is used in embedded/file mode by default (no server needed).
# Set this only if you are running a standalone Qdrant server.
QDRANT_URL=http://localhost:6333

# ── Ollama ────────────────────────────────────────────────────────────────────
# URL of your Ollama server (must be running before starting the platform)
OLLAMA_URL=http://localhost:11434

# ── Storage paths ────────────────────────────────────────────────────────────
# All paths are relative to the backend/ directory.
# You can change these to point to a larger drive if needed.
STORAGE_BASE=./storage
DATASETS_RAW_DIR=./storage/datasets/raw
DATASETS_CLEANED_DIR=./storage/datasets/cleaned
DATASETS_FORMATTED_DIR=./storage/datasets/formatted
DATASETS_TOKENIZED_DIR=./storage/datasets/tokenized
MODELS_HF_DIR=./storage/models/hf
CHECKPOINTS_DIR=./storage/checkpoints
MERGED_MODELS_DIR=./storage/merged_models
GGUF_EXPORTS_DIR=./storage/gguf_exports
RAG_DOCUMENTS_DIR=./storage/rag_documents

# ── HuggingFace ───────────────────────────────────────────────────────────────
# Cache directory for downloaded HuggingFace models
HF_HOME=./storage/models/hf

# HuggingFace API token — required only for gated/private models
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=
